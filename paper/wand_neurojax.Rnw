<<tab-perfusion, results='asis'>>=
trust_file <- file.path(perf_dir, "trust_results.json")
if (file.exists(trust_file)) {
  trust <- jsonlite::fromJSON(trust_file)
  cat("\\begin{table}[htbp]\n\\centering\n")
  cat("\\caption{Perfusion measurements (ses-03).}\n")
