  cat("Blood T1 (3T default) & 1650 ms \\\\\n")
  cat("Venous blood T2 (TRUST) & ", round(trust$T2_blood_ms, 1), " ms \\\\\n")
  if (!is.null(trust$SvO2)) cat("SvO$_2$ & ", round(trust$SvO2 * 100, 1), "\\% \\\\\n")
  if (!is.null(trust$OEF)) cat("OEF & ", round(trust$OEF * 100, 1), "\\% \\\\\n")
  cat("\\bottomrule\n\\end{tabular}\n\\end{table}\n")
  cat("\\textit{Note: TRUST eTE calibration pending; SvO$_2$/OEF values require protocol-specific effective echo times.}\n")
}
@

\subsection{Thalamic nuclei (DTI-enhanced CNN)}

DTI-enhanced thalamic nuclei segmentation used the FreeSurfer CNN model
with FA and V1 maps from dtifit (CHARMED $b \leq 1200$\,s/mm$^2$, 83
volumes). 46 bilateral nuclei were identified.

<<tab-thalamic, results='asis'>>=
thal_csv <- file.path(fs_dir, "mri", "ThalamicNuclei_DTI_CNN_volumes.csv")
if (file.exists(thal_csv)) {
  thal <- read.csv(thal_csv, check.names = FALSE)
  cols <- names(thal)[-1]
  vals <- as.numeric(thal[1, -1])
  left_idx <- grep("^Left-", cols)
  esc <- function(x) gsub("_", "\\\\_", gsub("Left-ThalNuc-", "", x))
  cat("\\begin{table}[htbp]\n\\centering\n")
  cat("\\caption{Thalamic nuclei volumes (left hemisphere, mm$^3$).}\n")
  cat("\\begin{tabular}{lr|lr}\n\\toprule\n")
  cat("Nucleus & Vol. & Nucleus & Vol. \\\\\n\\midrule\n")
  half <- ceiling(length(left_idx) / 2)
  for (i in seq_len(half)) {
    j <- i + half
    cat(esc(cols[left_idx[i]]), " & ", round(vals[left_idx[i]], 0))
    if (j <= length(left_idx)) {
      cat(" & ", esc(cols[left_idx[j]]), " & ", round(vals[left_idx[j]], 0))
    } else { cat(" & & ") }
    cat(" \\\\\n")
  }
  cat("\\bottomrule\n\\end{tabular}\n\\end{table}\n")
} else { cat("Thalamic nuclei volumes not yet available.\n") }
@

